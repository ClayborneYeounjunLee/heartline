# 이 파일을 tools/.env 로 복사한 뒤 값을 채우세요. .env 는 절대 커밋 금지 (.gitignore 처리됨).

# Strava 앱 등록: https://www.strava.com/settings/api
#  - Authorization Callback Domain 에 "localhost" 입력
STRAVA_CLIENT_ID=
STRAVA_CLIENT_SECRET=

# 아래는 --auth → --token 과정에서 자동으로 채워짐 (직접 만질 필요 없음)
STRAVA_REFRESH_TOKEN=

# 집 위치 보호: 루트의 시작/끝에서 잘라낼 거리(m). 0 = 트리밍 안 함
TRIM_METERS=200

# 가져올 활동 종류 (쉼표 구분)
ACTIVITY_TYPES=Run,TrailRun,VirtualRun

# 한 번에 확인할 최근 활동 최대 개수
MAX_ACTIVITIES=200
